# API Keys (rename to .env and fill in your keys)

# football-data.org API (FREE - register at https://www.football-data.org/)
FOOTBALL_DATA_API_KEY=your_api_key_here

# NewsAPI (for news articles - register at https://newsapi.org/)
NEWS_API_KEY=your_newsapi_key_here

# Hugging Face (optional, for private models)
HUGGINGFACE_TOKEN=your_hf_token_here

# Streamlit Deployment
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost
